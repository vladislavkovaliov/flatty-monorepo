{
  "name": "go-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/go-api/cmd",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go build -o dist/apps/go-api/api ./cmd/api/",
        "cwd": "apps/go-api"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run ./cmd/api/",
        "cwd": "apps/go-api"
      }
    },
    "hot": {
      "executor": "nx:run-commands",
      "options": {
        "command": "PATH=\"$HOME/go/bin:$PATH\" air",
        "cwd": "apps/go-api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test ./...",
        "cwd": "apps/go-api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "staticcheck ./...",
        "cwd": "apps/go-api"
      }
    }
  },
  "tags": ["scope:backend", "type:api"]
}
