# =============================================================================
# docker-compose variable substitution
# Copy this file to .env at the repository root to customize Docker deployment:
#   cp .env.example .env
#
# docker-compose automatically reads .env and substitutes ${VAR} references in
# docker-compose.yml. Each variable has a default value (:-default syntax) so
# .env is optional for basic usage.
# =============================================================================

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=flatty

# -- go-api -------------------------------------------------------------------
GOAPI_PORT=8080
GOAPI_DATABASE_URL=postgres://postgres:password@postgres:5432/flatty?sslmode=disable
GOAPI_KAFKA_BROKERS=redpanda:9092
GOAPI_RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
GOAPI_AUTH_SERVICE_URL=http://nest-graphql:3000

# -- nest-graphql -------------------------------------------------------------
NEST_PORT=3000
NEST_DATABASE_URL=postgres://postgres:password@postgres:5432/flatty
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:80

# -- react-wrapper (build-time) -----------------------------------------------
# For local dev: PORT=8080 (direct to go-api)
# For Docker:    PORT=80   (via nginx-proxy)
WRAPPER_PUBLIC_PROTOCOL=http
WRAPPER_PUBLIC_URL=localhost
WRAPPER_PUBLIC_PORT=80
WRAPPER_PUBLIC_PATH=api/swagger/doc.json

# -- react-resident (build-time) ----------------------------------------------
RESIDENT_PUBLIC_PROTOCOL=http
RESIDENT_PUBLIC_URL=localhost
RESIDENT_PUBLIC_PORT=80
RESIDENT_PUBLIC_PATH=api/swagger/doc.json
