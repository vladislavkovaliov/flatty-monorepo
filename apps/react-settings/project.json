{
  "name": "react-settings",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/react-settings/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack --mode production",
        "cwd": "apps/react-settings"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev",
        "cwd": "apps/react-settings"
      }
    }
  },
  "tags": ["scope:frontend", "type:remote"]
}
