# go-api local development
# Copy to .env in this directory:
#   cp .env.example .env
#
# For Docker deployment, these vars are set via docker-compose environment
# blocks or the root .env file.

PORT=8080
DATABASE_URL=postgres://postgres:password@localhost:55000/flatty?sslmode=disable
KAFKA_BROKERS=localhost:9092
RABBITMQ_URL=amqp://guest:guest@localhost:5672
