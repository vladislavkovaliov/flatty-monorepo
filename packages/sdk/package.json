{
  "name": "@flatty-budget/sdk",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "api": "npx dotenv -e .env -- sh -c 'npx swagger-typescript-api generate -p \"${SWAGGER_URL}\" -o src/types -n api.ts --no-client --extract-request-params --extract-response-body'",
    "graphql:codegen": "npx graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/typescript": "^6.1.0",
    "@graphql-codegen/typescript-operations": "^6.1.0",
    "dotenv-cli": "^11.0.0",
    "swagger-typescript-api": "^13.0.0"
  }
}
