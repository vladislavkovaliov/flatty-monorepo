{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "declaration": true,
    "outDir": "./dist",
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["src"]
}
