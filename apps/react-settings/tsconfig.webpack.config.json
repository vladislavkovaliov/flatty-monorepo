{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "noEmit": false,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "module": "esnext",
    "target": "es6",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "lib": ["es2016", "dom", "ES2018.Promise"],
    "baseUrl": "."
  },
  "exclude": ["node_modules"]
}