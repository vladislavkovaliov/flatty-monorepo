# nest-graphql local development
# Copy to .env in this directory:
#   cp .env.example .env
#
# For Docker deployment, these vars are set via docker-compose environment
# blocks or the root .env file.

PORT=3000
DATABASE_URL=postgres://postgres:password@localhost:55000/flatty

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Email (SMTP)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=
EMAIL_FROM=noreply@flattybudget.com

# Magic Link
MAGIC_LINK_CALLBACK_URL=http://localhost:9000/accept-invite
